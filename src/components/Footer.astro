---
import { countByRoute } from '../lib/data.js';
const total = Object.values(countByRoute).reduce((a, b) => a + b, 0);
---

<footer class="site-footer">
  <div class="wrap inner">
    <div class="col">
      <p class="line">满纸荒唐言，一把辛酸泪。</p>
      <p class="line dim">都云作者痴，谁解其中味。</p>
    </div>
    <nav class="links" aria-label="页脚导航">
      <a href="/characters" class="plain">人物</a>
      <a href="/poems" class="plain">诗词</a>
      <a href="/fate" class="plain">命运·判词</a>
      <a href="/chapters" class="plain">章节</a>
      <a href="/graph" class="plain">关系图谱</a>
      <a href="/search" class="plain">检索</a>
    </nav>
    <p class="meta">
      基于 Obsidian 知识库生成 · {total} 个词条 · 涵盖百二十回<br />
      <span class="dim2">水墨黑白 · 朱砂钤印 · 沉浸式知识浏览</span>
    </p>
  </div>
</footer>

<style>
  .site-footer { position: relative; z-index: 1; background: var(--paper-sunk); color: var(--ink-2); margin-top: 5rem; border-top: 1px solid var(--ink-hair); }
  .inner { display: grid; gap: 1.6rem; padding-block: 3rem; grid-template-columns: 1fr auto 1fr; align-items: center; }
  .col .line { font-size: 1.05rem; color: var(--ink); line-height: 1.85; letter-spacing: .08em; }
  .col .line.dim { color: var(--ink-faint); }
  .links { display: flex; flex-wrap: wrap; gap: .3rem 1.2rem; justify-content: center; }
  .links a { color: var(--ink-2); font-size: .95rem; }
  .links a:hover { color: var(--ink); }
  .meta { text-align: right; font-size: .82rem; color: var(--ink-faint); line-height: 1.7; }
  .dim2 { letter-spacing: .14em; }
  @media (max-width: 780px) {
    .inner { grid-template-columns: 1fr; text-align: center; gap: 1.3rem; }
    .meta { text-align: center; }
  }
</style>
