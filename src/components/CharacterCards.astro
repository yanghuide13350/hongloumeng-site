---
import { characters, pageById } from '../lib/data.js';

const { filter, title } = Astro.props;

// 根据不同的过滤条件显示人物
const filtered = characters.filter(filter || (() => true));

// 为每个人物获取封面图
const withCovers = filtered.map(char => {
  const page = pageById(char.id);
  return {
    ...char,
    cover: page?.cover || page?.images?.[0] || null
  };
});
---

<div class="char-cards">
  {withCovers.map(char => (
    <a href={`/characters/${char.slug}`} class="char-card plain">
      {char.cover && (
        <div class="cc-img">
          <img src={char.cover} alt={char.title} loading="lazy" decoding="async" />
        </div>
      )}
      <div class="cc-body">
        <h3 class="cc-name">{char.title}</h3>
        {char.role && <p class="cc-role">{char.role}</p>}
        {char.home && <p class="cc-meta">居所：{char.home}</p>}
        {char.fate && <p class="cc-fate">{Array.isArray(char.fate) ? char.fate.join('、') : char.fate}</p>}
        {char.verdictKw && <p class="cc-verdict">{char.verdictKw}</p>}
      </div>
    </a>
  ))}
</div>

<style>
  .char-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.2rem;
    margin: 2rem 0;
  }

  .char-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--paper-2);
    border: 1px solid var(--ink-hair);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all var(--speed) var(--ease);
    box-shadow: var(--shadow-sm);
  }

  .char-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: var(--ink-faint);
  }

  .cc-img {
    position: relative;
    width: 100%;
    height: 220px;
    overflow: hidden;
    background: var(--paper-sunk);
  }

  .cc-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.3);
    transition: all 0.6s var(--ease);
  }

  .char-card:hover .cc-img img {
    filter: grayscale(0);
    transform: scale(1.05);
  }

  .cc-body {
    padding: 1.2rem 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .cc-name {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--ink);
    margin: 0;
    font-weight: 600;
  }

  .cc-role {
    font-size: 0.88rem;
    color: var(--ink-2);
    font-weight: 500;
  }

  .cc-meta {
    font-size: 0.82rem;
    color: var(--ink-faint);
    margin: 0;
  }

  .cc-fate {
    font-size: 0.85rem;
    color: var(--cinnabar);
    margin-top: 0.3rem;
    font-weight: 500;
  }

  .cc-verdict {
    font-family: var(--serif);
    font-size: 0.9rem;
    color: var(--ink-2);
    font-style: italic;
    margin-top: 0.2rem;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .char-cards {
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1rem;
    }

    .cc-img {
      height: 180px;
    }
  }
</style>
