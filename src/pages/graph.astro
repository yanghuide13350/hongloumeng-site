---
import Base from '../layouts/Base.astro';
import { graph, FAMILY_COLOR } from '../lib/data.js';

const charNodes = graph.nodes.filter((n) => n.type === '人物');
const families = [...new Set(charNodes.map((n) => n.family).filter(Boolean))];
const byFam = {};
for (const n of charNodes) { const f = n.family || '其它'; (byFam[f] = byFam[f] || []).push(n); }
const famList = Object.entries(byFam).sort((a, b) => b[1].length - a[1].length);
---

<Base title="人物关系网络" description="红楼梦人物关系网络 —— 九十余位人物、数百条互链结成的一张谱，按家族高亮。" wide>
  <div class="wrap g-wrap">
    <header class="ghead" data-reveal>
      <div>
        <span class="seal seal--lg">图谱</span>
        <h1>人物关系网络</h1>
      </div>
      <p class="gsub">{charNodes.length} 位人物，按出场互动结成的一张谱。悬停某人高亮其关系，点击进入词条；按家族筛选。</p>
    </header>

    <div class="controls" data-reveal>
      <button class="chip on" type="button" data-fam="">全部</button>
      {families.map((f) => (
        <button class="chip" type="button" data-fam={f} style={`--fc:${FAMILY_COLOR[f] || '#8C887E'}`}>
          <span class="swatch" style={`background:${FAMILY_COLOR[f] || '#8C887E'}`}></span>{f}
        </button>
      ))}
    </div>

    <div id="cy" role="application" aria-label="人物关系交互图">
      <div class="cy-loading" id="cy-loading"><span class="spin"></span>结网中…</div>
    </div>
    <p class="ghint">拖拽平移 · 滚轮缩放 · 悬停高亮关系 · 点击进入人物</p>

    <!-- 移动端降级 -->
    <div class="g-fallback" id="g-fallback">
      <p class="fb-note">移动端以列表呈现；桌面端可查看交互式关系网。</p>
      {famList.map(([fam, ns]) => (
        <section class="fam-group">
          <h3 style={`--fc:${FAMILY_COLOR[fam] || '#8C887E'}`}>{fam}<span>{ns.length} 人</span></h3>
          <div class="fam-people">{ns.map((n) => <a href={`/${n.typeRoute}/${n.slug}`} class="tag">{n.title}</a>)}</div>
        </section>
      ))}
    </div>
  </div>

  <script>
    if (!matchMedia('(max-width: 780px)').matches) {
      const [{ default: cytoscape }, { default: fcose }] = await Promise.all([import('cytoscape'), import('cytoscape-fcose')]);
      cytoscape.use(fcose);

      const { FAMILY_COLOR } = await import('../lib/color.js');
      const colorOf = (f) => FAMILY_COLOR[f] || '#8C887E';

      const { nodes, edges } = await (await fetch('/graph.json')).json();
      // 聚焦人物子图
      const charSet = new Set(nodes.filter((n) => n.type === '人物').map((n) => n.id));
      const cNodes = nodes.filter((n) => charSet.has(n.id));
      const cEdges = edges.filter((e) => charSet.has(e.source) && charSet.has(e.target));
      const deg = {};
      cEdges.forEach((e) => { deg[e.source] = (deg[e.source] || 0) + 1; deg[e.target] = (deg[e.target] || 0) + 1; });

      const css = getComputedStyle(document.documentElement);
      const v = (n, d) => css.getPropertyValue(n).trim() || d;
      const paper = v('--paper', '#F3EFE4'), ink = v('--ink', '#1A1813'), jade = v('--jade', '#1E6B5C'), hair = v('--ink-hair', '#E2DAC7'), cinnabar = v('--cinnabar', '#A6382B');

      const elements = [
        ...cNodes.map((n) => ({ data: { id: n.id, label: n.title, route: n.typeRoute, slug: n.slug, family: n.family || '其它', color: colorOf(n.family), size: 16 + Math.sqrt(deg[n.id] || 1) * 5.5, minor: (deg[n.id] || 0) < 4 } })),
        ...cEdges.map((e) => ({ data: { source: e.source, target: e.target, w: 0.5 + Math.min(e.weight, 6) * 0.5 } })),
      ];

      const cy = cytoscape({
        container: document.getElementById('cy'),
        elements,
        wheelSensitivity: 0.25,
        minZoom: 0.3, maxZoom: 2.5,
        style: [
          { selector: 'node', style: {
            'background-color': 'data(color)', label: 'data(label)', width: 'data(size)', height: 'data(size)',
            'border-width': 2.5, 'border-color': paper, 'font-size': 12, 'font-family': 'serif', color: ink,
            'text-valign': 'center', 'text-halign': 'center', 'text-outline-color': paper, 'text-outline-width': 2.5,
            'min-zoomed-font-size': 9, 'transition-property': 'opacity, border-color, border-width', 'transition-duration': '0.25s',
          } },
          { selector: 'edge', style: { 'line-color': jade, width: 'data(w)', 'curve-style': 'bezier', opacity: 0.22, 'transition-property': 'opacity, line-color, width', 'transition-duration': '0.25s' } },
          { selector: 'node[?minor]', style: { 'text-opacity': 0 } },
          { selector: '.dim', style: { opacity: 0.07, 'text-opacity': 0 } },
          { selector: 'node.hot', style: { 'border-color': cinnabar, 'border-width': 4, 'font-size': 15, 'min-zoomed-font-size': 0, 'z-index': 99, 'text-outline-width': 3, 'text-opacity': 1 } },
          { selector: 'edge.hot', style: { 'line-color': jade, opacity: 0.85, width: 2.5, 'z-index': 90 } },
        ],
        layout: { name: 'fcose', quality: 'proof', animate: false, randomize: true, nodeSeparation: 140, idealEdgeLength: 75, nodeRepulsion: 8500, padding: 50, packComponents: true },
      });

      cy.ready(() => { document.getElementById('cy-loading')?.remove(); cy.fit(undefined, 40); });

      const highlight = (node) => {
        const ego = node.closedNeighborhood();
        cy.elements().addClass('dim');
        ego.removeClass('dim').addClass('hot');
      };
      cy.on('mouseover', 'node', (e) => highlight(e.target));
      cy.on('mouseout', 'node', () => cy.elements().removeClass('dim hot'));
      cy.on('tap', 'node', (e) => { const d = e.target.data(); if (d.route && d.slug) location.href = `/${d.route}/${d.slug}`; });

      document.querySelectorAll('[data-fam]').forEach((btn) => btn.addEventListener('click', () => {
        document.querySelectorAll('[data-fam]').forEach((b) => b.classList.remove('on'));
        btn.classList.add('on');
        const fam = btn.getAttribute('data-fam');
        cy.elements().removeClass('dim hot');
        if (!fam) return;
        const fns = cy.nodes().filter((n) => n.data('family') === fam);
        cy.elements().addClass('dim');
        fns.removeClass('dim').addClass('hot');
        fns.connectedEdges().removeClass('dim');
        fns.neighborhood().removeClass('dim');
      }));
    }
  </script>

  <style>
    .g-wrap { padding-top: 1rem; }
    .ghead { display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 1.4rem; }
    .ghead h1 { font-size: clamp(2rem, 1.5rem + 2.4vw, 3.2rem); margin-top: .5rem; }
    .gsub { color: var(--ink-faint); max-width: 34rem; line-height: 1.7; font-size: .92rem; }
    .controls { display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 1rem; }
    .chip { display: inline-flex; align-items: center; gap: .4rem; font-family: var(--serif); font-size: .85rem; padding: .25em .8em; border: 1px solid var(--ink-hair); background: var(--paper-2); color: var(--ink-2); border-radius: 999px; cursor: pointer; transition: all var(--speed) var(--ease); }
    .chip:hover { border-color: var(--fc, var(--jade)); color: var(--fc, var(--jade)); }
    .chip.on { background: var(--fc, var(--jade)); border-color: var(--fc, var(--jade)); color: #fff; }
    .chip.on .swatch { box-shadow: 0 0 0 1.5px #fff; }
    .swatch { width: .7rem; height: .7rem; border-radius: 50%; display: inline-block; }
    #cy { width: 100%; height: 78vh; min-height: 32rem; background:
      radial-gradient(120% 100% at 50% 0%, color-mix(in srgb, var(--jade) 5%, var(--paper-2)), var(--paper-2));
      border: 1px solid var(--ink-hair); border-radius: var(--radius); position: relative; box-shadow: var(--shadow-sm) inset; }
    .cy-loading { position: absolute; inset: 0; display: flex; gap: .7rem; align-items: center; justify-content: center; color: var(--ink-faint); letter-spacing: .2em; font-size: 1.05rem; }
    .spin { width: 1.1rem; height: 1.1rem; border: 2px solid var(--ink-hair); border-top-color: var(--jade); border-radius: 50%; animation: sp 0.8s linear infinite; }
    @keyframes sp { to { transform: rotate(360deg); } }
    .ghint { margin-top: .8rem; color: var(--ink-faint); font-size: .82rem; text-align: center; letter-spacing: .04em; }
    .g-fallback { display: none; }
    .fb-note { color: var(--ink-faint); font-size: .85rem; margin-bottom: 1.4rem; text-align: center; }
    .fam-group { margin-bottom: 1.6rem; }
    .fam-group h3 { display: flex; align-items: baseline; gap: .5rem; font-size: 1.15rem; color: var(--fc); border-bottom: 1px solid var(--ink-hair); padding-bottom: .4rem; margin-bottom: .7rem; }
    .fam-group h3 span { font-size: .8rem; color: var(--ink-faint); font-weight: 400; }
    .fam-people { display: flex; flex-wrap: wrap; gap: .45rem; }
    @media (max-width: 780px) {
      .controls, #cy, .ghint { display: none; }
      .g-fallback { display: block; }
    }
  </style>
</Base>
